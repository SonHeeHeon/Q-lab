# =============================================================================
# Q-Lab — Environment Variables Template
# =============================================================================
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Loaded by `shared/utils/config.py` via pydantic-settings.
#
# All 3 KIS accounts (paper / real / ISA) are configured here. Switch the
# active account with KIS_DEFAULT_ACCOUNT.
# =============================================================================

# === KIS — Paper (모의투자) ===
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PAPER_ACCOUNT_NO=

# === KIS — Real Ordinary (실전 일반) ===
KIS_REAL_APP_KEY=
KIS_REAL_APP_SECRET=
KIS_REAL_ACCOUNT_NO=

# === KIS — Real ISA (실전 ISA) ===
KIS_ISA_APP_KEY=
KIS_ISA_APP_SECRET=
KIS_ISA_ACCOUNT_NO=

# Which account is selected by default when none is specified
KIS_DEFAULT_ACCOUNT=PAPER

# TLS verification for KIS HTTPS requests.
# Keep KIS_SSL_VERIFY=true unless you are doing a short local diagnostic.
# If your network uses a security proxy with a custom root CA, export it as PEM
# and point KIS_CA_BUNDLE_PATH to that file.
KIS_SSL_VERIFY=true
KIS_CA_BUNDLE_PATH=

# === KIS WebSocket ===
KIS_WS_AUTOSTART=true
KIS_WS_DEFAULT_CODES=005930
KIS_WS_RECONNECT_MAX_SECONDS=60

# === Toss Securities Open API ===
# Toss uses OAuth2 client_credentials. WebSocket streaming is not available in
# the provided Toss Open API 1.1.1 spec, so realtime paths use REST polling.
TOSS_API_BASE_URL=https://openapi.tossinvest.com
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=
TOSS_ACCOUNT_SEQ=
TOSS_IS_MOCK=true
TOSS_HTTP_TIMEOUT_SECONDS=10
TOSS_SSL_VERIFY=true
TOSS_CA_BUNDLE_PATH=

# === Intraday Heatmap Snapshot ===
# During Korean trading sessions, cache KOSPI200 current prices in memory every
# 5 minutes for /api/heatmap?market=KOSPI. Disable this if KIS credentials are
# not configured or you only want research DB close-price heatmaps.
MARKET_SNAPSHOT_AUTOSTART=true
MARKET_SNAPSHOT_ACCOUNT_TYPE=PAPER
MARKET_SNAPSHOT_INTERVAL_MINUTES=5
MARKET_SNAPSHOT_REQUEST_CONCURRENCY=8
MARKET_SNAPSHOT_REQUEST_INTERVAL_SECONDS=0.35
MARKET_SNAPSHOT_STALE_AFTER_MINUTES=10
MARKET_SESSION_PRE_MARKET_START=08:00
MARKET_SESSION_PRE_MARKET_END=08:50
MARKET_SESSION_REGULAR_START=09:00
MARKET_SESSION_REGULAR_END=15:30
MARKET_SESSION_AFTER_HOURS_START=15:30
MARKET_SESSION_AFTER_HOURS_END=20:00

# === KIS Order Tracking ===
# Poll locally submitted open orders and reconcile actual fills/fees/taxes.
ORDER_TRACKER_AUTOSTART=true
ORDER_TRACKER_POLL_INTERVAL_SECONDS=30
ORDER_TRACKER_ORDER_TIMEOUT_SECONDS=300

# === Auto Trading Safety ===
# Rebalancer and risk-manager live orders are dry-run by default. Flip these
# only after validating in paper trading.
AUTOMATION_KILL_SWITCH=false
AUTOMATION_MAX_ORDER_VALUE=5000000
AUTOMATION_MAX_DAILY_LOSS_PCT=-5.0
REBALANCER_IS_MOCK=true
REBALANCER_MIN_TRADE_VALUE=50000
REBALANCER_CASH_BUFFER_PCT=0.005
RISK_MANAGER_AUTOSTART=false
RISK_MANAGER_IS_MOCK=true
RISK_MANAGER_ACCOUNT_TYPE=PAPER
RISK_MANAGER_STOP_LOSS_PCT=-10.0
RISK_MANAGER_POSITION_REFRESH_SECONDS=60

# === Alert Monitor ===
# Keeps alert CRUD separate from execution safety. When enabled, pending alerts
# are checked every N seconds. BUY/SELL alert actions are dry-run by default.
ALERT_MONITOR_AUTOSTART=false
ALERT_MONITOR_INTERVAL_SECONDS=60
ALERT_ORDER_IS_MOCK=true
ALERT_DEFAULT_BROKER=KIS

# === KRX / pykrx ===
# Leave these empty unless your pykrx/KRX environment explicitly requires them.
# The research loader can still run smoke tests without these values.
KRX_ID=
KRX_PW=

# === LLM ===
LLM_PROVIDER=openai
OPENAI_API_KEY=
LLM_MODEL=gpt-4o
LLM_DAILY_TOKEN_BUDGET=200000
LLM_CACHE_TTL_HOURS=24

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SSL_VERIFY=true
TELEGRAM_CA_BUNDLE_PATH=

# === DART OpenAPI (재무제표) ===
DART_API_KEY=

# === Local DB / Cache paths ===
SERVICE_DB_PATH=data/service.db
RESEARCH_DB_PATH=data/research.db
TOKEN_CACHE_DIR=data/tokens
LLM_CACHE_DIR=data/cache

# === Batch Scheduler ===
# Keep disabled during local UI/API development unless you want scheduled jobs
# to call OpenAI/Telegram automatically.
BATCH_SCHEDULER_AUTOSTART=false
APSCHEDULER_TIMEZONE=Asia/Seoul
DAILY_ANALYSIS_CRON="30 16 * * MON-FRI"
DAILY_REPORT_CRON="45 16 * * MON-FRI"
DATA_SYNC_CRON="0 18 * * MON-FRI"
BROKER_ORDER_SYNC_CRON="10 16 * * MON-FRI"
BROKER_ORDER_SYNC_LOOKBACK_DAYS=7
BROKER_ORDER_SYNC_ACCOUNTS=PAPER,REAL,ISA
DEFAULT_STRATEGY_NAME=value_v1

# === Misc ===
LOG_LEVEL=INFO
LOG_DIR=logs/backend
LOG_BACKUP_DAYS=14
TZ=Asia/Seoul
